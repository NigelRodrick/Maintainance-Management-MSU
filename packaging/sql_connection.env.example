# SQL Server — copy this file to:
#   %LOCALAPPDATA%\MSUMaintenance\.env
# (That path overrides other settings when the EXE or python app starts.)
#
# Requires Microsoft ODBC Driver 18 for SQL Server on the PC:
#   winget install Microsoft.msodbcsql.18
#
# Use SQL authentication (matches Docker compose in repo root docker-compose.yml):
USE_SQLITE=0
FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-string
DB_SERVER=localhost
DB_NAME=CentralServices_AM_DB
DB_USER=sa
DB_PASSWORD=MsuSqlSetup!2026Strong
#
# Windows integrated auth instead: leave DB_USER and DB_PASSWORD empty or delete them:
# DB_SERVER=localhost\\SQLEXPRESS
# DB_NAME=CentralServices_AM_DB